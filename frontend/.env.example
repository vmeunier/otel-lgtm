# Configuration OpenTelemetry (optionnel)
# Décommentez et configurez si vous souhaitez exporter les traces vers un collecteur OTLP

# URL du collecteur OTLP (ex: Grafana Tempo, Jaeger, etc.)
# VITE_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces

# Activer/désactiver l'export des traces
# VITE_OTEL_TRACES_ENABLED=true

# Nom du service (par défaut: frontend-ecommerce)
# VITE_SERVICE_NAME=frontend-ecommerce
